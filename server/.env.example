# Copy this file to .env and fill in your real values.
# .env is already in .gitignore - it will never be committed or shipped to the browser.

# Your MongoDB Atlas connection string (with a NEW password after rotating the old one)
MONGODB_URI=mongodb+srv://your_user:your_new_password@cluster1.q1x0czg.mongodb.net/prepdeck?appName=Cluster1

# Any long random string - used to sign login tokens. Generate one with:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string

# Port the server runs on
PORT=4000

# Your deployed frontend URL, for CORS (use http://localhost:5173 while testing locally)
CLIENT_ORIGIN=http://localhost:5173
